
{
  "entities": {
    "ZakatCalculation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ZakatCalculation",
      "type": "object",
      "description": "Stores a historical record of a user's Zakat calculation based on various assets.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "calculationDate": { "type": "string", "format": "date-time" },
        "cashAmount": { "type": "number" },
        "goldValue": { "type": "number" },
        "savingsAmount": { "type": "number" },
        "businessAssetsAmount": { "type": "number" },
        "calculatedZakat": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "calculationDate", "cashAmount", "goldValue", "savingsAmount", "businessAssetsAmount", "calculatedZakat"]
    },
    "EidGreeting": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "EidGreeting",
      "type": "object",
      "description": "Represents a personalized Eid greeting generated by a user.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "recipientName": { "type": "string" },
        "templateId": { "type": "string" },
        "generatedImageUrl": { "type": "string", "format": "uri" },
        "generationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "recipientName", "templateId", "generationDate"]
    },
    "SalamiEntry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SalamiEntry",
      "type": "object",
      "description": "Records an individual 'salami' (monetary gift) transaction tracked by the user.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "personName": { "type": "string" },
        "amount": { "type": "number" },
        "entryDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "personName", "amount", "entryDate"]
    },
    "SalamiCard": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SalamiCard",
      "type": "object",
      "description": "A digital Salami envelope sent from one user to another.",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "recipientName": { "type": "string" },
        "message": { "type": "string" },
        "amount": { "type": "number" },
        "paymentLink": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderName", "recipientName", "createdAt"]
    },
    "SavedMosque": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SavedMosque",
      "type": "object",
      "description": "A mosque saved by a user for quick access.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "mosqueId": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "lat": { "type": "number" },
        "lon": { "type": "number" },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "savedAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "user",
          "description": "Base collection for user profiles."
        }
      },
      {
        "path": "/users/{userId}/zakatCalculations/{id}",
        "definition": {
          "entityName": "ZakatCalculation",
          "description": "User Zakat history."
        }
      },
      {
        "path": "/users/{userId}/eidGreetings/{id}",
        "definition": {
          "entityName": "EidGreeting",
          "description": "Generated Eid greetings."
        }
      },
      {
        "path": "/users/{userId}/salamiEntries/{id}",
        "definition": {
          "entityName": "SalamiEntry",
          "description": "Salami tracker entries."
        }
      },
      {
        "path": "/users/{userId}/savedMosques/{id}",
        "definition": {
          "entityName": "SavedMosque",
          "description": "User's saved mosques."
        }
      },
      {
        "path": "/salamiCards/{id}",
        "definition": {
          "entityName": "SalamiCard",
          "description": "Digital Salami envelopes sent by users."
        }
      }
    ]
  }
}
