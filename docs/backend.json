
{
  "entities": {
    "ReceivedSalami": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ReceivedSalami",
      "type": "object",
      "description": "Represents a record of salami money received by a user during Eid celebrations.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier."
        },
        "userId": {
          "type": "string",
          "description": "Owner of the record."
        },
        "amount": {
          "type": "number",
          "description": "The amount received."
        },
        "fromPerson": {
          "type": "string",
          "description": "Who gave the salami."
        },
        "receivedAt": {
          "type": "string",
          "description": "Timestamp.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "amount",
        "receivedAt"
      ]
    },
    "EidSelfie": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "EidSelfie",
      "type": "object",
      "description": "An Eid selfie photo for the contest.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "imageUrl": {
          "type": "string",
          "format": "uri"
        },
        "caption": {
          "type": "string"
        },
        "likesCount": {
          "type": "number"
        },
        "uploadedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "imageUrl",
        "uploadedAt"
      ]
    },
    "SalamiCard": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SalamiCard",
      "type": "object",
      "description": "A digital Eidi envelope/card that can be shared via link.",
      "properties": {
        "id": {
          "type": "string"
        },
        "senderName": {
          "type": "string"
        },
        "recipientName": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "paymentLink": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "senderName",
        "recipientName",
        "createdAt"
      ]
    },
    "AppNotification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AppNotification",
      "type": "object",
      "description": "An in-app notification for the user.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["greeting", "like", "mosque", "moon", "jamaat"]
        },
        "isRead": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "title", "isRead", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/receivedSalami/{salamiId}",
        "definition": {
          "entityName": "ReceivedSalami",
          "schema": {
            "$ref": "#/backend/entities/ReceivedSalami"
          },
          "description": "User's personal salami records."
        }
      },
      {
        "path": "/users/{userId}/notifications/{notificationId}",
        "definition": {
          "entityName": "AppNotification",
          "schema": {
            "$ref": "#/backend/entities/AppNotification"
          },
          "description": "User's personal notifications."
        }
      },
      {
        "path": "/eidSelfies/{selfieId}",
        "definition": {
          "entityName": "EidSelfie",
          "schema": {
            "$ref": "#/backend/entities/EidSelfie"
          },
          "description": "Public selfie contest entries."
        }
      },
      {
        "path": "/salamiCards/{cardId}",
        "definition": {
          "entityName": "SalamiCard",
          "schema": {
            "$ref": "#/backend/entities/SalamiCard"
          },
          "description": "Publicly accessible digital eidi envelopes."
        }
      }
    ]
  }
}
