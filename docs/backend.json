
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within EidSpark, including their gamification progress and personal details.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "totalPoints": { "type": "number" },
        "levelId": { "type": "string" },
        "earnedBadgeIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "totalPoints", "levelId", "earnedBadgeIds", "createdAt"]
    },
    "SalamiProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SalamiProfile",
      "type": "object",
      "description": "A user's personal QR Salami page configuration.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "bkashNumber": { "type": "string" },
        "nagadNumber": { "type": "string" },
        "message": { "type": "string" },
        "totalSalami": { "type": "number" },
        "donorsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "username", "bkashNumber"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/salamiProfiles/{profileId}",
        "definition": {
          "entityName": "SalamiProfile",
          "schema": { "$ref": "#/backend/entities/SalamiProfile" },
          "description": "Stores personal Salami QR profiles."
        }
      }
    ]
  }
}
