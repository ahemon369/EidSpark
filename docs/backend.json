
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within EidSpark, including their gamification progress and personal details.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "totalPoints": { "type": "number" },
        "levelId": { "type": "string" },
        "earnedBadgeIds": { "type": "array", "items": { "type": "string" } },
        "streak": { "type": "number", "default": 0 },
        "privacy": { "type": "string", "enum": ["public", "friends", "private"], "default": "public" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "totalPoints", "levelId", "earnedBadgeIds", "createdAt"]
    },
    "SalamiProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SalamiProfile",
      "type": "object",
      "description": "A user's personal QR Salami page configuration.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "bkashNumber": { "type": "string" },
        "nagadNumber": { "type": "string" },
        "message": { "type": "string" },
        "totalSalami": { "type": "number" },
        "donorsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "username", "bkashNumber"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/users/{userId}/savedExcuses/{id}",
        "definition": {
          "schema": { "type": "object" },
          "description": "User's saved viral excuses."
        }
      },
      {
        "path": "/users/{userId}/savedMosques/{id}",
        "definition": {
          "schema": { "type": "object" },
          "description": "User's favorite prayer locations."
        }
      },
      {
        "path": "/users/{userId}/salamiEntries/{id}",
        "definition": {
          "schema": { "type": "object" },
          "description": "User's personal salami collection log."
        }
      },
      {
        "path": "/users/{userId}/eidGreetings/{id}",
        "definition": {
          "schema": { "type": "object" },
          "description": "User's AI-generated greeting cards."
        }
      },
      {
        "path": "/users/{userId}/zakatCalculations/{id}",
        "definition": {
          "schema": { "type": "object" },
          "description": "User's zakat calculation history."
        }
      },
      {
        "path": "/users/{userId}/notifications/{id}",
        "definition": {
          "schema": { "type": "object" },
          "description": "User's in-app activity notifications."
        }
      },
      {
        "path": "/users/{userId}/dailyChallengeProgress/{id}",
        "definition": {
          "schema": { "type": "object" },
          "description": "User's progress on daily Eid challenges."
        }
      },
      {
        "path": "/users/{userId}/selfiePosters/{id}",
        "definition": {
          "schema": { "type": "object" },
          "description": "User's AI-themed festive selfies."
        }
      },
      {
        "path": "/salamiProfiles/{profileId}",
        "definition": {
          "entityName": "SalamiProfile",
          "schema": { "$ref": "#/backend/entities/SalamiProfile" },
          "description": "Stores personal Salami QR profiles."
        }
      },
      {
        "path": "/mosques/{mosqueId}",
        "definition": {
          "schema": { "type": "object" },
          "description": "Global registry of mosques and prayer grounds."
        }
      },
      {
        "path": "/mosques/{mosqueId}/jamaatTimes/{id}",
        "definition": {
          "schema": { "type": "object" },
          "description": "Community-reported Eid prayer times for a mosque."
        }
      },
      {
        "path": "/eidSelfies/{id}",
        "definition": {
          "schema": { "type": "object" },
          "description": "Public entries for the national Eid selfie contest."
        }
      },
      {
        "path": "/salamiCards/{id}",
        "definition": {
          "schema": { "type": "object" },
          "description": "Digital eidi envelopes sent between users."
        }
      },
      {
        "path": "/moonSightings/{id}",
        "definition": {
          "schema": { "type": "object" },
          "description": "Crowd-sourced moon sighting reports across Bangladesh."
        }
      }
    ]
  }
}
