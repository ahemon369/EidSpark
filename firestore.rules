
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isExistingOwnerOrAdmin(ownerId) {
      return resource != null && (isOwner(ownerId) || isAdmin());
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /mosques/{mosqueId} {
      allow list: if true;
      allow get: if resource.data.isApprovedByAdmin == true || isExistingOwnerOrAdmin(resource.data.submittedByUserId);
      allow create: if isSignedIn() && request.resource.data.submittedByUserId == request.auth.uid;
      allow update: if isExistingOwnerOrAdmin(resource.data.submittedByUserId);
      allow delete: if isExistingOwnerOrAdmin(resource.data.submittedByUserId);

      match /jamaatTimes/{jamaatTimeId} {
        allow list: if true;
        allow get: if resource.data.isApprovedByAdmin == true || isExistingOwnerOrAdmin(resource.data.submittedByUserId);
        allow create: if isSignedIn() && request.resource.data.submittedByUserId == request.auth.uid;
        allow update, delete: if isExistingOwnerOrAdmin(resource.data.submittedByUserId);
      }
    }

    match /moonSightings/{sightingId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /salamiCards/{cardId} {
      allow get: if true;
      allow create: if isSignedIn();
      allow list, update, delete: if isAdmin();
    }

    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
  }
}
