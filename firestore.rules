
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // User-specific data
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();

      // Nested subcollections for user data
      match /savedExcuses/{id} { allow read, write: if isOwner(userId); }
      match /savedMosques/{id} { allow read, write: if isOwner(userId); }
      match /salamiEntries/{id} { allow read, write: if isOwner(userId); }
      match /eidGreetings/{id} { allow read, write: if isOwner(userId); }
      match /zakatCalculations/{id} { allow read, write: if isOwner(userId); }
      match /dailyChallengeProgress/{id} { allow read, write: if isOwner(userId); }
      match /selfiePosters/{id} { allow read, write: if isOwner(userId); }
      
      match /notifications/{id} { 
        allow get, list, update, delete: if isOwner(userId);
        allow create: if isSignedIn(); 
      }
    }

    // Global Mosque Registry
    match /mosques/{mosqueId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.submittedByUserId == request.auth.uid);
      
      match /jamaatTimes/{id} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    // Community Contest
    match /eidSelfies/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Digital Eidi Envelopes
    match /salamiCards/{id} {
      allow get: if true;
      allow create: if isSignedIn();
    }

    // Salami QR Profiles
    match /salamiProfiles/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.userId) || isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalSalami', 'donorsCount']));
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Moon Sighting Registry
    match /moonSightings/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Admin Roles
    match /roles_admin/{userId} {
      allow get: if isOwner(userId);
    }
  }
}
