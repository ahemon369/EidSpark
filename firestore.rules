/**
 * EidSpark: Live Eid Jamaat Finder - Security Rules
 * =================================================
 * 
 * Core Philosophy:
 * This ruleset implements a robust, multi-tiered security model designed for community-driven data 
 * with administrative oversight. It prioritizes "Authorization Independence" by ensuring that 
 * sub-resources (like prayer times) carry their own authorization state, minimizing expensive cross-document lookups.
 * 
 * Data Structure:
 * - /users/{userId}: Private user profiles and subcollections, strictly owner-accessible.
 * - /roles_admin/{userId}: Administrative role registry (DBAC).
 * - /mosques/{mosqueId}: Publicly viewable mosque registry (once approved) with contributor ownership.
 * - /mosques/{mosqueId}/jamaatTimes/{jamaatTimeId}: Individual prayer times linked to mosques.
 * 
 * Key Security Decisions:
 * 1. Admin Hierarchy: A dedicated /roles_admin collection identifies global admins who can bypass 
 *    approval checks and moderate all content.
 * 2. Denormalized Ownership: All user-submitted content (Mosques and JamaatTimes) includes a 
 *    'submittedByUserId' field. This allows the rules to verify authorship instantly without joins.
 * 3. Atomic Approval: The 'isApprovedByAdmin' flag is present on both parent (Mosque) and child (JamaatTime) 
 *    documents. This allows prayer times to be verified and displayed even if the mosque's metadata 
 *    is updated, while preventing unverified data from appearing in public searches.
 * 4. Structural Segregation: Administrative roles are kept in a separate root collection to 
 *    prevent pollution of the user profile schema and provide a clear audit trail for privileges.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user is registered as an administrator. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Checks if the user is the original submitter or an admin, and verifies the document exists. */
    function isExistingOwnerOrAdmin(ownerId) {
      return resource != null && (isOwner(ownerId) || isAdmin());
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profiles. Only the user themselves can read or write their profile and subcollections.
     * @path /users/{userId}
     * @allow get, list, create, update, delete: if isOwner(userId)
     * @principle Ownership: Restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);

      /**
       * @description Rules for user-specific subcollections (e.g., zakatCalculations, eidGreetings).
       *              Recursively allows access to all sub-documents if the user is the owner.
       */
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Rules for the admin role registry. Read access is allowed for signed-in users 
     *              to facilitate rule checks; writes are strictly limited to existing admins.
     * @path /roles_admin/{userId}
     * @allow get: if isSignedIn();
     * @deny create: if !isAdmin() (only admins can promote others)
     * @principle Roles: Centralized DBAC (Database Access Control) for administrative privileges.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for Mosques. Public can read approved mosques. Registered users can submit new ones.
     *              Updates and deletes are restricted to the original submitter or admins.
     * @path /mosques/{mosqueId}
     * @allow get: if resource.data.isApprovedByAdmin == true || isAdmin() || isOwner(resource.data.submittedByUserId)
     * @allow create: if isSignedIn() && request.resource.data.submittedByUserId == request.auth.uid
     * @deny delete: if !isOwner(resource.data.submittedByUserId) && !isAdmin()
     * @principle Public Read with Owner-Only Writes: Protects content integrity while allowing public consumption.
     */
    match /mosques/{mosqueId} {
      // List is allowed for all to support the map/search feature; client-side filtering by approved status is expected.
      allow list: if true;
      allow get: if resource.data.isApprovedByAdmin == true || isExistingOwnerOrAdmin(resource.data.submittedByUserId);
      
      allow create: if isSignedIn() && request.resource.data.submittedByUserId == request.auth.uid;
      
      allow update: if isExistingOwnerOrAdmin(resource.data.submittedByUserId) 
                    && (isAdmin() || request.resource.data.submittedByUserId == resource.data.submittedByUserId);
                    
      allow delete: if isExistingOwnerOrAdmin(resource.data.submittedByUserId);

      /**
       * @description Rules for individual Eid prayer times. Follows the same approval/ownership logic as mosques.
       * @path /mosques/{mosqueId}/jamaatTimes/{jamaatTimeId}
       * @allow get: if resource.data.isApprovedByAdmin == true || isAdmin() || isOwner(resource.data.submittedByUserId)
       * @principle Authorization Independence: Child documents are secured by their own fields to avoid parent lookups.
       */
      match /jamaatTimes/{jamaatTimeId} {
        allow list: if true;
        allow get: if resource.data.isApprovedByAdmin == true || isExistingOwnerOrAdmin(resource.data.submittedByUserId);
        
        allow create: if isSignedIn() && request.resource.data.submittedByUserId == request.auth.uid 
                      && request.resource.data.mosqueId == mosqueId;
        
        allow update: if isExistingOwnerOrAdmin(resource.data.submittedByUserId)
                      && (isAdmin() || request.resource.data.submittedByUserId == resource.data.submittedByUserId);
                      
        allow delete: if isExistingOwnerOrAdmin(resource.data.submittedByUserId);
      }
    }

    /**
     * @description Rules for Moon Sightings. Publicly readable for the interactive map.
     *              Registered users can submit their sightings.
     *              Only the original reporter or an admin can delete a report.
     * @path /moonSightings/{sightingId}
     */
    match /moonSightings/{sightingId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    /**
     * @description Rules for Salami Cards (Digital Envelopes).
     *              Readable by anyone with the unique magic link (id).
     *              Created by registered users.
     */
    match /salamiCards/{cardId} {
      allow get: if true;
      allow create: if isSignedIn();
      allow list, update, delete: if isAdmin();
    }

    /**
     * @description Rules for the Global Leaderboard.
     *              Publicly readable. Updated by users when they add a Salami entry.
     */
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
  }
}
