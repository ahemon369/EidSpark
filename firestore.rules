
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/savedExcuses/{id} {
      allow get, list, create, delete: if isOwner(userId);
    }

    match /users/{userId}/savedMosques/{id} {
      allow get, list, create, delete: if isOwner(userId);
    }

    match /users/{userId}/salamiEntries/{id} {
      allow get, list, create, delete: if isOwner(userId);
    }

    match /users/{userId}/eidGreetings/{id} {
      allow get, list, create, delete: if isOwner(userId);
    }

    match /users/{userId}/zakatCalculations/{id} {
      allow get, list, create, delete: if isOwner(userId);
    }

    match /users/{userId}/notifications/{id} {
      allow get, list, update, delete: if isOwner(userId);
      allow create: if isSignedIn();
    }

    match /users/{userId}/dailyChallengeProgress/{id} {
      allow get, list, create, update: if isOwner(userId);
    }

    match /mosques/{mosqueId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.submittedByUserId == request.auth.uid);
    }

    match /eidSelfies/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /salamiCards/{id} {
      allow get: if true;
      allow create: if isSignedIn();
    }

    match /salamiProfiles/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.userId) || isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalSalami', 'donorsCount']));
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /moonSightings/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /roles_admin/{userId} {
      allow get: if isOwner(userId);
    }
  }
}
