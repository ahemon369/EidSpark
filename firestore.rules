rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * EIDSPARK SECURITY RULES DOCUMENTATION
     *
     * Core Philosophy: 
     * This ruleset implements a strict "User-Ownership" model. Every piece of data is logically 
     * and physically scoped to a specific user. Access is granted only if the authenticated 
     * user's UID matches the segment of the document path that identifies the owner.
     *
     * Data Structure:
     * The hierarchy follows a flat-nesting pattern under the root /users collection:
     * - /users/{userId}: Primary profile document.
     * - /users/{userId}/zakatCalculations/{id}: Historical Zakat asset records.
     * - /users/{userId}/eidGreetings/{id}: User-generated greeting cards.
     * - /users/{userId}/salamiEntries/{id}: Transaction logs for monetary gifts.
     *
     * Key Security Decisions:
     * 1. Authorization Independence: Every document contains its owner's UID (userId) 
     *    directly on the record. This allows rules to perform fast, efficient checks 
     *    without needing to traverse the tree using get() calls.
     * 2. Strict Privacy: There are no public read or list permissions. All data is 
     *    private to the owner. User listing is disabled.
     * 3. Relational Integrity: On creation, the rules enforce that the internal 'userId' 
     *    field matches the authenticated user's UID and the path ID.
     * 4. Prototyping Flexibility: While ownership is strictly enforced, the specific 
     *    shape and data types of content fields (like 'notes' or 'amount') are not 
     *    validated here to allow for rapid iteration.
     */

    // --- Helper Functions ---

    /**
     * @description Basic check to see if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Ensures the user is the owner AND the document being accessed exists.
     * Used for update and delete operations to prevent actions on non-existent data.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the root user profile document.
     * @path /users/{userId}
     * @allow (get) If the request.auth.uid matches the userId.
     * @deny (list) Global listing of users is forbidden.
     * @principle Ownership and path-to-data consistency.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users should not be listable
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      /**
       * @description Historical Zakat calculations performed by the user.
       * @path /users/{userId}/zakatCalculations/{zakatCalculationId}
       * @allow (create) If userId matches auth and data.userId matches path.
       * @deny (get) If a user tries to access another user's calculation.
       * @principle Authorization Independence via denormalized userId.
       */
      match /zakatCalculations/{zakatCalculationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Personalized Eid greetings generated by the user.
       * @path /users/{userId}/eidGreetings/{eidGreetingId}
       * @allow (list) If the authenticated user is listing their own subcollection.
       * @deny (update) If the user attempts to change the owner of the greeting.
       * @principle Immutable ownership field and user-scoped listing.
       */
      match /eidGreetings/{eidGreetingId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Salami (gift) entry records for the Salami Tracker.
       * @path /users/{userId}/salamiEntries/{salamiEntryId}
       * @allow (delete) If the owner deletes their own record.
       * @deny (create) If the incoming data.userId does not match the path or auth UID.
       * @principle Relational integrity and resource-level access control.
       */
      match /salamiEntries/{salamiEntryId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}